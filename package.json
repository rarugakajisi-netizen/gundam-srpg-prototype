{
  "name": "gundam-srpg-prototype",
  "version": "0.1.1",
  "private": true,
  "description": "A browser-based card tactical SRPG prototype.",
  "type": "commonjs",
  "scripts": {
    "start": "python -m http.server 8765",
    "check": "node work/run-checks.js",
    "check:js": "node work/run-checks.js --syntax-only",
    "check:data": "node work/check-game-data.js",
    "check:data:strict": "node work/check-game-data.js --warnings-as-errors",
    "check:play": "node work/check-play-integrity.js",
    "check:ai": "node work/check-enemy-ai.js",
    "check:recon": "node work/check-recon.js",
    "check:barricade": "node work/check-barricade.js",
    "check:priority-target": "node work/check-priority-target.js",
    "check:precision-repair": "node work/check-precision-repair.js",
    "check:formations": "node work/check-formations.js",
    "check:last-stand": "node work/check-last-stand-options.js",
    "check:tem-ray-parts": "node work/check-tem-ray-parts.js",
    "check:images": "node work/check-card-images.js",
    "package": "node work/package-release.js",
    "package:plicy": "node work/package-release.js --target plicy",
    "report:balance": "node work/card-balance-report.js",
    "report:balance:json": "node work/card-balance-report.js --json"
  },
  "keywords": [
    "srpg",
    "prototype",
    "browser-game"
  ],
  "license": "UNLICENSED"
}
